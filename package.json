{
  "name": "ac27-level-editor",
  "version": "1.1.5",
  "description": "Cross-platform Level Editor for Airport Control 27 .acl flight schedules",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "start": "vite",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:all": "node tests/run-all.mjs",
    "build": "vite build",
    "build:win": "vite build && electron-builder --win portable --x64",
    "build:mac": "vite build && electron-builder --mac",
    "build:all": "vite build && electron-builder --win --mac"
  },
  "build": {
    "appId": "com.ac27.level-editor",
    "productName": "AC27 Level Editor",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "node_modules/**/*"
    ],
    "win": {
      "target": "portable",
      "icon": "icon.ico",
      "artifactName": "AC27LevelEditor.${ext}"
    },
    "mac": {
      "target": "dmg",
      "icon": "icon.png",
      "category": "public.app-category.utilities",
      "artifactName": "AC27LevelEditor.${ext}"
    }
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@vitejs/plugin-react": "^6.0.2",
    "electron": "^33.0.0",
    "electron-builder": "^25.1.8",
    "jsdom": "^29.1.1",
    "png-to-ico": "^3.0.1",
    "rcedit": "^5.0.2",
    "sharp": "^0.34.5",
    "vite": "^8.0.16",
    "vite-plugin-electron": "^1.0.0",
    "vitest": "^4.1.8"
  },
  "dependencies": {
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-icons": "^5.6.0",
    "zustand": "^5.0.14"
  }
}
